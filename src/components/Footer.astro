---
import { profileConfig } from '../config'
import { url } from '../utils/url-utils'
import { Icon } from "astro-icon/components";
---

<script>
function updateFooterIcon() {
    const footerIcon = document.getElementById('footer-icon') as HTMLImageElement;
    const alistIcon = document.getElementById('alist-icon') as HTMLImageElement;
    if (document.documentElement.classList.contains('dark')) {
        footerIcon.src = '/favicon/Oathblade-dark.svg';
        alistIcon.src = '/favicon/alist-dark.svg';
    } else {
        footerIcon.src = '/favicon/Oathblade-light.svg';
        alistIcon.src = '/favicon/alist-light.svg';
    }
}

// 初始化时更新图片
updateFooterIcon();

// 监听主题变化
document.addEventListener('theme:change', updateFooterIcon);
</script>

<div class="card-base max-w-[var(--page-width)] min-h-[4.5rem] rounded-b mx-auto px-4 pt-4 pb-4">
    <div class="text-50 text-sm">
        <div>
            © 2024 {profileConfig.name}. All Rights Reserved.
        </div>
        <div class="flex gap-2 mt-0.5">
            <a class="link text-[var(--primary)] font-medium inline-flex items-center" target="_blank" href={url('rss.xml')}>
                <Icon name="material-symbols:rss-feed" class="mr-0.2" />RSS
            </a>
            <span class="mx-1">|</span>
            <a class="link text-[var(--primary)] font-medium inline-flex items-center" target="_blank" href={url('sitemap-index.xml')}>
                <Icon name="material-symbols:map-outline" class="mr-0.2" />Site Map
            </a>
            <span class="mx-1">|</span>
            <a class="link text-[var(--primary)] font-medium inline-flex items-center" target="_blank" href="https://alist.oathblade.com/">
                <img id="alist-icon" src="/favicon/alist-light.svg" alt="Alist Icon" class="w-3.5 h-3.5 mr-0.2" />Alist
            </a>
        </div>
        <div class="flex gap-1 mt-0.5">
            Powered by 
            <a class="link text-[var(--primary)] font-medium inline-flex items-center" target="_blank" href="https://astro.build"><Icon name="simple-icons:astro" class="mr-0.2" />Astro</a>. 
            Theme by 
            <a class="link text-[var(--primary)] font-medium inline-flex items-center" target="_blank" href="https://fuwari.vercel.app/"><Icon name="emojione-monotone:fish-cake-with-swirl" class="mr-0.5 ml-0.5" />Fuwari</a>. 
        </div>
    </div>
    <img id="footer-icon" src="/favicon/Oathblade-light.svg" alt="Site Icon" class="absolute right-4 top-1/2 transform -translate-y-1/2 w-16 h-16" />
</div>